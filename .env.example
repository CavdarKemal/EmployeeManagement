# ── Datenbank ─────────────────────────────────────────────
POSTGRES_DB=employeemanagement
POSTGRES_USER=employeemanagement
POSTGRES_PASSWORD=          # PFLICHT: mindestens 20 Zeichen, z.B.: openssl rand -base64 24

# ── Backend / JWT ──────────────────────────────────────────
JWT_SECRET=                 # PFLICHT: mindestens 32 Zeichen, z.B.: openssl rand -base64 48
JWT_EXPIRATION_MS=86400000

# ── Frontend ───────────────────────────────────────────────
# Leer lassen! Der nginx-Proxy im Frontend-Container leitet /api/ weiter.
VITE_API_BASE_URL=
