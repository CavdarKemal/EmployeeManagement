# Vaultwarden — Produktions-Konfiguration
# Kopie als .env auf der VPS unter /opt/vaultwarden/.env ablegen, chmod 600.

# Volle URL inkl. Schema (Browser-Extensions verlangen exaktes Match)
DOMAIN=https://vault.em.cavdar.de

# Argon2id-Hash erzeugen mit:
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# (Falls --rm -it im SSH nicht geht, als Alternative argon2-CLI:
#   apt install argon2
#   echo -n "DEIN_PASSWORT" | argon2 "$(openssl rand -base64 16)" -id -t 3 -k 65540 -p 4 -l 32 -e )
#
# !!! WICHTIG !!! Jedes `$` im Hash MUSS als `$$` geschrieben werden, sonst
# interpretiert Docker Compose die Hash-Bestandteile als Variable-Refs und
# der Token kommt zerlegt im Container an (Vaultwarden fällt dann auf
# Plain-Text-Fallback zurück, Log-Zeile: "plain text ADMIN_TOKEN"). Im
# Beispiel unten sind die `$$` schon korrekt — den eigenen Hash ebenso doppeln.
ADMIN_TOKEN=$$argon2id$$v=19$$m=65540,t=3,p=4$$REPLACE_SALT$$REPLACE_HASH

# SMTP für Invite-Mails — gleiche Gmail-Credentials wie EmployeeManagement
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_FROM=kemal@cavdar.de
SMTP_FROM_NAME=EmployeeManagement Vault
SMTP_USERNAME=kemal@cavdar.de
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
